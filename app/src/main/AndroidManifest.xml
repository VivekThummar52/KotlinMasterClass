            android:name=".features.jobdiscovery.JobDiscoveryActivity"
            android:exported="false"
            android:label="@string/title_activity_job_discovery"
            android:theme="@style/Theme.KotlinMasterclass" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.KotlinMasterclass">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>